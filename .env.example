PAN_FW_URL=mgmt-pa1420-a.domain.local
PAN_API_KEY=your_api_key_here
ISERV_GEO_URL=https://iserv.nl/files/edl/out/country/

# Email Report Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
# SMTP_SECURE can be: tls, ssl, or none. Defaults to tls on 587, ssl on 465, none otherwise.
SMTP_SECURE=tls
# Set to true to skip certificate verification (common for internal relays)
SMTP_ALLOW_INSECURE=false
SMTP_FROM=stats@example.com
REPORT_RECIPIENT=admin@example.com
